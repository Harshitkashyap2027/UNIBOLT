// --- INITIAL LOAD ---
window.onload = () => { setupRealtimeListener(); };

function setupRealtimeListener() {
    const tbody = document.getElementById("table-body");
    
    if(allStudents.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:20px;">Loading...</td></tr>`;
    }

    const q = query(collection(db, "users"), orderBy("paymentDate", "desc"));

    onSnapshot(q, (snapshot) => {
        allStudents = [];
        let pendingCount = 0;
        let revenue = 0;

        snapshot.forEach(docSnap => {
            const data = docSnap.data();
            data.uid = docSnap.id;
            allStudents.push(data);

            if(data.paymentStatus === "Pending") pendingCount++;
            if(data.paymentStatus === "Verified") revenue += 200;
        });

        document.getElementById("stat-total").innerText = allStudents.length;
        document.getElementById("stat-pending").innerText = pendingCount;
        document.getElementById("stat-rev").innerText = "₹" + revenue.toLocaleString();

        filterTable();

    }, (error) => {
        console.error("Error fetching data:", error);
        showToast("Error loading data", "error");
        tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; color:red;">Error loading data. Check console.</td></tr>`;
    });
}

function renderTable(data) {
    const tbody = document.getElementById("table-body");
    tbody.innerHTML = "";

    if(data.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:20px;">No students found matching current filter.</td></tr>`;
        return;
    }

    data.forEach(s => {
        const badgeClass = s.paymentStatus === 'Verified' ? 'verified' : (s.paymentStatus === 'Pending' ? 'pending' : 'rejected');
        const avatar = s.avatarIcon || "👤";
        
        const approveBtn = s.paymentStatus !== 'Verified' 
            ? `<button class="btn-icon btn-approve" title="Approve Student" onclick="window.quickApprove('${s.uid}')"><i class="fa-solid fa-check"></i></button>`
            : '';

        const row = `
            <tr>
                <td>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="background:#222; width:35px; height:35px; border-radius:50%; display:flex; justify-content:center; align-items:center; font-size:18px;">${avatar}</div>
                        <div>
                            <div style="font-weight:bold; color:white;">${s.name || "No Name"}</div>
                            <div style="font-size:11px; color:#666;">${s.email}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <div style="color:white; font-size:13px;">${s.enrolledProgram || "N/A"}</div>
                    <div style="font-size:11px; color:#666;">${s.degree || "Degree"} • ${s.year || "Year"}</div>
                </td>
                <td>
                    <div style="font-family:monospace; color:#e4e4e7; font-size:13px; letter-spacing:1px;">
                        ${s.transactionId || "NO UTR"}
                    </div>
                    <span class="badge ${badgeClass}" style="margin-top:4px;">${s.paymentStatus || "Unknown"}</span>
                </td>
                <td style="text-align:right;">
                    ${approveBtn}
                    <button class="btn-icon btn-reset" title="Reset Progress" onclick="window.quickReset('${s.uid}')"><i class="fa-solid fa-rotate-left"></i></button>
                    <button class="btn-icon" title="Broadcast" onclick="window.openBroadcastModal('${s.uid}', '${s.name}')"><i class="fa-solid fa-envelope"></i></button>
                    <button class="btn-icon" title="Edit" onclick="window.openEdit('${s.uid}')"><i class="fa-solid fa-pen"></i></button>
                    <button class="btn-icon btn-delete" title="Delete" onclick="window.deleteUser('${s.uid}')"><i class="fa-solid fa-trash"></i></button>
                </td>
            </tr>
        `;
        tbody.innerHTML += row;
    });
}

// --- FILTER LOGIC ---
window.filterTable = function(searchVal = "") {
    const courseFilter = document.getElementById("course-filter").value;
    
    if (!searchVal) {
        searchVal = document.querySelector(".search-bar").value;
    }
    const lowerSearch = searchVal.toLowerCase();

    const filtered = allStudents.filter(s => {
        const matchesCourse = courseFilter === "all" || s.enrolledProgram === courseFilter;
        const matchesSearch = 
            (s.name && s.name.toLowerCase().includes(lowerSearch)) || 
            (s.email && s.email.toLowerCase().includes(lowerSearch)) || 
            (s.transactionId && s.transactionId.toLowerCase().includes(lowerSearch));

        return matchesCourse && matchesSearch;
    });

    renderTable(filtered);
}

// --- QUICK ACTIONS ---
window.quickReset = function(uid) {
    const confirmModal = document.getElementById("confirm-modal");
    const confirmBtn = document.getElementById("confirm-yes");
    const confirmTitle = confirmModal.querySelector('h2');
    const confirmText = confirmModal.querySelector('p');

    // Update text for Reset
    confirmTitle.innerText = "Reset Progress?";
    confirmText.innerText = "This will set XP and Streaks back to zero.";
    confirmBtn.innerText = "Yes, Reset";
    
    confirmModal.classList.add("active");

    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);

    newConfirmBtn.onclick = async () => {
        confirmModal.classList.remove("active");
        try {
            await updateDoc(doc(db, "users", uid), { xp: 0, streak: 0, completedTasks: [] });
            showToast("Progress has been reset", "info");
        } catch(e) { showToast("Reset failed", "error"); }
    };
}

window.quickApprove = async function(uid) {
    if(!confirm("Approve this student instantly?")) return;
    try {
        await updateDoc(doc(db, "users", uid), { paymentStatus: "Verified" });
        showToast("Student Approved Successfully! ✅", "success");
    } catch(e) { showToast("Approval Failed: " + e.message, "error"); }
}

