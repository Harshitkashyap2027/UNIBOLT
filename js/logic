// --- FORM SUBMIT ---
document.getElementById("student-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const uid = document.getElementById("inp-uid").value;
    const btn = e.target.querySelector("button[type=submit]");
    const originalText = btn.innerText;
    btn.innerText = "Processing...";
    btn.disabled = true;

    const newPass = document.getElementById("inp-tempPass").value;

    const formData = {
        name: document.getElementById("inp-name").value,
        phone: document.getElementById("inp-phone").value,
        avatarIcon: document.getElementById("inp-avatarIcon").value,
        state: document.getElementById("inp-state").value,
        city: document.getElementById("inp-city").value,
        college: document.getElementById("inp-college").value,
        year: document.getElementById("inp-year").value,
        degree: document.getElementById("inp-degree").value,
        enrolledProgram: document.getElementById("inp-enrolledProgram").value,
        paymentStatus: document.getElementById("inp-paymentStatus").value,
        transactionId: document.getElementById("inp-transactionId").value,
        paymentDate: document.getElementById("inp-paymentDate").value,
        xp: Number(document.getElementById("inp-xp").value),
        streak: Number(document.getElementById("inp-streak").value)
    };

    if(newPass.trim() !== "") formData.tempPassword = newPass;

    try {
        if(uid) {
            await updateDoc(doc(db, "users", uid), formData);
            showToast("Student Updated Successfully! 📝", "success");
        } else {
            formData.email = document.getElementById("inp-email").value;
            if(!newPass || newPass.length < 6) {
                showToast("Password too short (min 6)", "error");
                btn.innerText = originalText;
                btn.disabled = false;
                return;
            }
            const secondaryApp = initializeApp(firebaseConfig, "Secondary");
            const secondaryAuth = getAuth(secondaryApp);
            const userCred = await createUserWithEmailAndPassword(secondaryAuth, formData.email, newPass);
            await setDoc(doc(db, "users", userCred.user.uid), { 
                ...formData, 
                createdAt: new Date(), 
                notifications: [], 
                completedTasks: [] 
            });
            await signOut(secondaryAuth);
            showToast("New Student Created! 🚀", "success");
        }
        window.closeModal("student-modal");
    } catch (err) {
        showToast("Error: " + err.message, "error");
    } finally {
        btn.innerText = originalText;
        btn.disabled = false;
    }
});

// --- BROADCAST ---
window.openBroadcastModal = function(uid, name) {
    document.getElementById("broadcast-modal").classList.add("active");
    document.getElementById("bc-target-uid").value = uid;
    document.getElementById("bc-target-name").innerText = uid === 'all' ? "Everyone (All Students)" : name;
    document.getElementById("bc-message").value = "";
}

window.sendBroadcast = async function() {
    const targetUid = document.getElementById("bc-target-uid").value;
    const message = document.getElementById("bc-message").value;
    if(!message.trim()) {
        showToast("Message cannot be empty", "error");
        return;
    }

    const notifObj = { message: message, date: new Date().toLocaleDateString(), read: false };
    const btn = document.querySelector("#broadcast-modal .btn-primary");
    btn.innerText = "Sending...";
    btn.disabled = true;

    try {
        if(targetUid === 'all') {
            const promises = allStudents.map(async (student) => {
                const userRef = doc(db, "users", student.uid);
                const currentNotifs = student.notifications || [];
                await updateDoc(userRef, { notifications: [...currentNotifs, notifObj] });
            });
            await Promise.all(promises);
            showToast("Sent to Everyone! 📢", "success");
        } else {
            const userRef = doc(db, "users", targetUid);
            const snap = await getDoc(userRef);
            if(snap.exists()) {
                const currentNotifs = snap.data().notifications || [];
                await updateDoc(userRef, { notifications: [...currentNotifs, notifObj] });
                showToast("Sent Privately 📨", "success");
            }
        }
        window.closeModal("broadcast-modal");
    } catch(e) { showToast("Broadcast Failed", "error"); } 
    finally { btn.innerText = "Send Message"; btn.disabled = false; }
}

// --- UTILS ---
window.closeModal = function(id) { document.getElementById(id).classList.remove("active"); }

window.deleteUser = function(uid) {
    const confirmModal = document.getElementById("confirm-modal");
    const confirmBtn = document.getElementById("confirm-yes");

    // 1. Show the custom modal
    confirmModal.classList.add("active");

    // 2. Clear old event listeners from the "Yes" button
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);

    // 3. Handle the "Yes" click
    newConfirmBtn.onclick = async () => {
        try {
            // Close modal immediately
            confirmModal.classList.remove("active");
            
            // Perform delete
            await deleteDoc(doc(db, "users", uid));
            
            // Show your custom toast
            showToast("Record deleted successfully", "error");
        } catch (e) {
            showToast("Error deleting record", "error");
            console.error(e);
        }
    };
}

/**
 * REUSABLE POPUP SYSTEM
 */
function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toast-msg');
    const toastIcon = toast.querySelector('i');

    toastMsg.textContent = message;
    
    // Apply types for colors (success, error, info)
    toast.className = `toast show ${type}`;
    
    // Set appropriate icon
    if (type === 'success') toastIcon.className = 'fa-solid fa-circle-check';
    else if (type === 'error') toastIcon.className = 'fa-solid fa-circle-exclamation';
    else if (type === 'info') toastIcon.className = 'fa-solid fa-circle-info';

    // Auto hide
    setTimeout(() => {
        toast.classList.remove('show');
    }, 3000);
}

