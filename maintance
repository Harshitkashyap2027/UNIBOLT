            <div style="display:flex; align-items:center; gap:15px;">
                <span class="status-badge">● SYSTEM ONLINE</span>
                <button class="preview-btn" onclick="togglePreview()"><i class="fa-solid fa-eye"></i> Preview Design</button>
            </div>
        </div>

        <div class="content-area">
            <div class="list-panel" id="listPanel">
                <div class="list-header">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <span style="font-weight:bold; font-size:13px; color:#94a3b8;">STUDENT DATABASE</span>
                        <button class="mini-btn" id="bulkToggle" onclick="toggleBulkMode()">Select Multiple</button>
                    </div>
                    <div class="bulk-controls" id="bulkControls" style="display:none;">
