            if(style === 'urgent' || style === 'failed' || style === 'reject' || style === 'pay_fail') return `<div style="background:#fee2e2;padding:40px;font-family:sans-serif;"><div style="max-width:600px;margin:auto;background:#fff;padding:30px;border-left:5px solid #ef4444;"><h2 style="color:#ef4444;">ACTION REQUIRED</h2><p>${text}</p>${btn}</div></div>`;

