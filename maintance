                        </optgroup>
                    </select>
                </div>

                <div class="form-group"><label>Subject</label><input type="text" id="emailSubject" placeholder="Email Subject..."></div>
                <div class="form-group"><label>Message Content</label><textarea id="emailBody" rows="6" placeholder="Write your message here..."></textarea></div>

                <div class="form-group">
                    <label>Custom Theme (30 Premium Designs)</label>
                    <div class="theme-grid" id="themeGrid"></div>
                    <input type="hidden" id="selectedTheme" value="review_pass">
                </div>

                <div class="form-group">
                    <label>Action Button</label>
                    <select id="actionButton">
                        <option value="none">No Button</option>
                        <option value="dashboard">📊 Go to Dashboard</option>
