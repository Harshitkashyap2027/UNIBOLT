                            <option value="maintain">🛠️ Maintenance</option>
                            <option value="policy">📜 Policy</option>
                            <option value="id_card">🪪 ID Card</option>
                            <option value="test">📝 Today's Test</option>
                            <option value="prepare">⚠️ Be Prepared</option>
                        </optgroup>
