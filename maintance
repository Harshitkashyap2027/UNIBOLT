            if(style === 'gold' || style === 'badge') return `<div style="background:#1a1a1a;padding:40px;font-family:serif;"><div style="border:2px solid #d4af37;padding:40px;color:#fff;text-align:center;max-width:600px;margin:auto;"><h1 style="color:#d4af37;letter-spacing:2px;">EXCLUSIVE</h1><div style="font-family:sans-serif;text-align:left;margin-top:30px;">${text}</div>${btn}</div></div>`;

            // 12. GLASS
            if(style === 'glass') return `<div style="background:linear-gradient(135deg,#4f46e5,#0ea5e9);padding:50px;font-family:sans-serif;"><div style="background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);padding:40px;border-radius:15px;color:white;max-width:600px;margin:auto;border:1px solid rgba(255,255,255,0.3);"><h3>Hi ${name},</h3>${text}${btn}</div></div>`;

            // 13. NEON
            if(style === 'neon') return `<div style="background:#090014;padding:40px;font-family:sans-serif;"><div style="border:1px solid #d946ef;padding:30px;border-radius:12px;color:#fff;box-shadow:0 0 20px #d946ef;max-width:600px;margin:auto;"><h2 style="color:#d946ef;text-shadow:0 0 10px #d946ef;">UniBolt</h2><div style="line-height:1.6;">${text}</div>${btn}</div></div>`;

            // 14. SUCCESS
            if(style === 'success' || style === 'pay_ok') return `<div style="background:#dcfce7;padding:40px;font-family:sans-serif;"><div style="background:white;padding:40px;border-radius:10px;text-align:center;max-width:600px;margin:auto;"><h1 style="color:#166534;">✅ SUCCESS</h1><p style="text-align:left;color:#333;">${text}</p>${btn}</div></div>`;

            // 15. INTERVIEW
            if(style === 'interview' || style === 'meeting' || style === 'webinar') return `<div style="background:#fff;padding:40px;font-family:sans-serif;"><div style="border-left:4px solid #3b82f6;padding-left:20px;max-width:600px;margin:auto;"><h2>📅 Invitation</h2><p>${text}</p>${btn}</div></div>`;

            // 16. STREAK
            if(style === 'streak') return `<div style="background:#fff7ed;padding:40px;font-family:sans-serif;text-align:center;"><h1 style="font-size:60px;margin:0;">🔥</h1><h2 style="color:#ea580c;">${studentData.streak || '5'} Day Streak!</h2><p>${text}</p>${btn}</div>`;

            // 17. TOP RANK
            if(style === 'rank') return `<div style="background:#1e1b4b;padding:40px;font-family:sans-serif;color:white;text-align:center;"><h1 style="color:#facc15;">👑 Rank #${studentData.rank || '15'}</h1><p>${text}</p><div style="margin-top:20px;padding:10px;background:rgba(255,255,255,0.1);border-radius:8px;">🚀 Keep trying and move up to get position in Top 10!</div>${btn}</div>`;

            // 18. FEEDBACK (Interactive)
            if(style === 'feedback') return `<div style="background:#fff7ed;padding:40px;font-family:sans-serif;text-align:center;"><div style="max-width:600px;margin:auto;"><h3>We Value Your Input</h3><p>${text}</p><div style="font-size:30px;margin:20px 0;"><a href="https://unibolt.in/rate/5" style="text-decoration:none;">⭐⭐⭐⭐⭐</a></div><p style="font-size:12px;color:#888;">Tap to Rate</p>${btn}</div></div>`;

            // 19. ID CARD
            if(style === 'id_card') return `<div style="background:#0f172a;padding:40px;font-family:sans-serif;color:white;"><div style="background:#1e293b;padding:30px;border-radius:12px;max-width:400px;margin:auto;text-align:center;border:1px solid #38bdf8;"><div style="width:80px;height:80px;background:#334155;border-radius:50%;margin:0 auto 15px;display:flex;align-items:center;justify-content:center;font-size:30px;">👤</div><h2>${name}</h2><p style="color:#94a3b8;">Student ID: UB-${Math.floor(Math.random()*1000)}</p>${btn}</div></div>`;

            // 20. TEST / PREPARE
            if(style === 'test' || style === 'prepare') return `<div style="background:#fff;padding:40px;font-family:sans-serif;border-left:8px solid #f59e0b;"><h2 style="color:#b45309;">📝 Assessment Alert</h2><p>${text}</p>${btn}</div>`;

            // Fallback for others (Referral, Maintain, Policy, Plain)
            return `<div style="padding:40px;font-family:sans-serif;background:#f1f5f9;"><div style="background:white;padding:40px;border-radius:8px;max-width:600px;margin:auto;box-shadow:0 4px 15px rgba(0,0,0,0.05);"><h3>Hello ${name},</h3><p style="color:#475569;line-height:1.6;">${text}</p>${btn}<hr style="border:0;border-top:1px solid #eee;margin:30px 0;"><p style="font-size:12px;color:#94a3b8;">UniBolt Team</p></div></div>`;
        }

        // --- 5. PREVIEW & SEND UI ---
        function togglePreview() {
            const m = document.getElementById('previewModal');
            if(m.style.display === 'flex') { m.style.display = 'none'; }
            else {
                m.style.display = 'flex';
                const theme = document.getElementById('selectedTheme').value;
                const body = document.getElementById('emailBody').value;
                const name = document.getElementById('targetName').value || "Student Name";
                const btnType = document.getElementById('actionButton').value;
                
                // MOCK DATA FOR PREVIEW IF NO STUDENT SELECTED
                let studentData = currentStudentData.id ? currentStudentData : { xp: '1200', rank: '12', streak: '7', badge: 'Bug Hunter' };
                
                document.getElementById('previewContainer').innerHTML = getDesignHTML(theme, body, name, btnType, studentData);
            }
        }

        function showToast(msg, type='success') {
            const t = document.getElementById('toast');
            t.innerText = msg;
            t.style.borderLeftColor = type==='error'?'#ef4444':'#38bdf8';
            t.classList.add('show');
            setTimeout(()=>t.classList.remove('show'),3000);
        }
    </script>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        // FIREBASE CONFIG (ADD YOURS)
        const app = initializeApp({
            apiKey: "AIzaSyCLaf8yGis2vT0DA4HlGlXXBKgFoCNGfDY",
            authDomain: "unibolt-f7005.firebaseapp.com",
            projectId: "unibolt-f7005",
            storageBucket: "unibolt-f7005.appspot.com",
            messagingSenderId: "121987854250",
            appId: "1:121987854250:web:21a9f50aad54b2143a85d3"
        });
        const db = getFirestore(app);
        
        let allStudents = [];
        let selectedStudentIds = new Set();
        let isBulkMode = false;

        // --- LOAD DATA ---
        async function loadData() {
            try {
                const snap = await getDocs(collection(db, "users"));
                allStudents = [];
                snap.forEach(d => {
                    const data = d.data();
                    allStudents.push({ 
                        id: d.id, 
                        name: data.name, 
                        email: data.email, 
                        avatar: data.avatarIcon || "👤",
                        xp: data.xp || 0,
                        rank: data.rank || 0,
                        streak: data.streak || 0
                    });
                });
                renderList(allStudents);
            } catch(e) { console.error(e); }
        }

        function renderList(data) {
            const list = document.getElementById('studentList');
            list.innerHTML = '';
            data.forEach(s => {
                const item = document.createElement('div');
                item.className = 'student-item';
                item.onclick = (e) => { 
                    if(e.target.type !== 'checkbox') {
                        if(isBulkMode) {
                            const cb = item.querySelector('.bulk-check');
                            cb.checked = !cb.checked;
                            updateBulkSelection(cb);
                        } else {
                            selectStudent(s, item);
                        }
                    }
                };
                const check = `<input type="checkbox" class="bulk-check" value="${s.id}" onchange="window.updateBulkSelection(this)">`;
                const content = isBulkMode ? check : `<div class="avatar">${s.avatar}</div>`;
                item.innerHTML = `${content}<div><div style="font-weight:bold;color:white;">${s.name}</div><div style="font-size:12px;color:#94a3b8;">${s.email}</div></div>`;
                list.appendChild(item);
            });
        }

        window.toggleBulkMode = function() {
            isBulkMode = !isBulkMode;
            document.getElementById('listPanel').classList.toggle('bulk-mode');
            document.getElementById('bulkControls').style.display = isBulkMode ? 'flex' : 'none';
            document.getElementById('selectedCount').style.display = isBulkMode ? 'block' : 'none';
            document.getElementById('bulkToggle').innerText = isBulkMode ? "Exit Bulk" : "Select Multiple";
            renderList(allStudents);
            selectedStudentIds.clear();
            document.getElementById('sendBtn').disabled = true;
        }

        window.updateBulkSelection = function(cb) {
            if(cb.checked) selectedStudentIds.add(cb.value);
            else selectedStudentIds.delete(cb.value);
            document.getElementById('selectedCount').innerText = `${selectedStudentIds.size} Selected`;
            document.getElementById('sendBtn').disabled = selectedStudentIds.size === 0;
        }

        window.selectAll = function() {
            document.querySelectorAll('.bulk-check').forEach(cb => { cb.checked = true; selectedStudentIds.add(cb.value); });
            window.updateBulkSelection({checked:true}); 
        }
        window.deselectAll = function() {
            document.querySelectorAll('.bulk-check').forEach(cb => { cb.checked = false; });
            selectedStudentIds.clear();
            window.updateBulkSelection({checked:false}); 
        }

        function selectStudent(s, el) {
            if(isBulkMode) return;
            document.querySelectorAll('.student-item').forEach(i => i.classList.remove('selected'));
            el.classList.add('selected');
            
            // CAPTURE DATA FOR THEME INJECTION
            window.currentStudentData = s; 

            document.getElementById('targetNameDisplay').innerText = `${s.name}`;
            document.getElementById('targetNameDisplay').style.color = '#22c55e';
            document.getElementById('targetEmail').value = s.email;
            document.getElementById('targetName').value = s.name;
            document.getElementById('sendBtn').disabled = false; // UNLOCKS BUTTON IMMEDIATELY
        }

        // --- SAFE SEND LOGIC (With Delay to Prevent Spam Block) ---
        
        // Helper function to create a pause
        const delay = (ms) => new Promise(resolve => setTimeout(resolve, ms));

        window.handleSend = async function() {
            const btn = document.getElementById('sendBtn');
            const toEmail = document.getElementById('targetEmail').value;
            const toName = document.getElementById('targetName').value;
            const sub = document.getElementById('emailSubject').value;
            const body = document.getElementById('emailBody').value;
            const theme = document.getElementById('selectedTheme').value;
            const btnType = document.getElementById('actionButton').value;
            const sender = document.getElementById('senderEmail').value;

            if(!sub || !body) return showToast("Subject or Body is empty!", "error");

            if(isBulkMode) {
                if(selectedStudentIds.size === 0) return showToast("No students selected", "error");
                const targets = allStudents.filter(s => selectedStudentIds.has(s.id));
                const total = targets.length;
                let count = 0;

                // UI Updates
                document.getElementById('progressContainer').style.display = 'block';
                document.getElementById('progressText').style.display = 'block';
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending (Safe Mode)...';

                for(const student of targets) {
                    count++;
                    const html = window.getDesignHTML(theme, body, student.name, btnType, student);
                    
                    try {
                        const res = await fetch('/api/send-email', {
                            method: 'POST',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify({ fromEmail: sender, toEmail: student.email, name: student.name, subject: sub, html: html })
                        });
                        
                        const data = await res.json();
                        if(!data.success) console.error("Failed to send to " + student.email);

                    } catch(e) { console.error(e); }
                    
                    // Update Progress Bar
                    const pct = (count / total) * 100;
                    document.getElementById('progressBar').style.width = `${pct}%`;
                    document.getElementById('progressText').innerText = `Sent ${count} of ${total}`;

                    // *** CRITICAL SPAM PROTECTION ***
                    // Wait 2 seconds before sending the next one
                    await delay(2000); 
                }

                showToast(`Finished sending to ${total} students!`, 'success');
                setTimeout(() => {
                    document.getElementById('progressContainer').style.display = 'none';
                    document.getElementById('progressText').style.display = 'none';
                    btn.disabled = false;
                    btn.innerHTML = 'Send Message <i class="fa-solid fa-paper-plane"></i>';
                }, 3000);

            } else {
                // SINGLE SEND
                if(!toEmail) return showToast("Select a student first!", "error");
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending...';
                btn.disabled = true;
                
                const html = window.getDesignHTML(theme, body, document.getElementById('targetName').value, btnType, window.currentStudentData || {});
                
                try {
                    const res = await fetch('/api/send-email', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ fromEmail: sender, toEmail: toEmail, name: document.getElementById('targetName').value, subject: sub, html: html })
                    });
                    const data = await res.json();
                    
                    if(data.success) { 
                        showToast("Sent Successfully!", "success"); 
                    } else { 
                        // If blocked, show the specific error
                        showToast("Error: " + data.message, "error"); 
                        alert("Zoho Blocked: " + data.message);
                    }
                } catch(e) { showToast("Server Error", "error"); }
                
                btn.innerHTML = 'Send Message <i class="fa-solid fa-paper-plane"></i>';
                btn.disabled = false;
            }
        }
        loadData();
    </script>
