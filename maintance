            // 8. SECURITY / OTP
            if(style === 'security' || style === 'otp' || style === 'reset') return `<div style="background:#f1f5f9;padding:40px;font-family:sans-serif;"><div style="max-width:500px;margin:auto;background:white;padding:30px;border-radius:8px;border-top:5px solid #4f46e5;"><h2 style="color:#4f46e5;">🛡️ Security Alert</h2><p>${text}</p>${btn}</div></div>`;

