            // --- 30 UNIQUE DESIGNS ---

            // 1. REVIEW PASS
            if(style === 'review_pass') return `<div style="font-family:sans-serif;background:#f9fafb;padding:40px;"><table style="border:1px solid #e5e7eb;border-radius:8px;background:#fff;width:100%;max-width:600px;margin:auto;" cellspacing="0"><tr><td style="padding:20px;border-bottom:1px solid #e5e7eb;background:#f9fafb;"><h3 style="margin:0;color:#111;">Project Update</h3><span style="background:#dcfce7;color:#16a34a;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:bold;float:right;margin-top:-20px;">APPROVED</span></td></tr><tr><td style="padding:30px;"><p style="color:#374151;">Hi ${name},</p><p style="color:#374151;">${text}</p>${btn}</td></tr></table></div>`;

