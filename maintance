            if(style === 'receipt') return `<div style="background:#f8fafc;padding:40px;font-family:monospace;color:#333;"><div style="max-width:500px;margin:auto;background:white;padding:30px;border:1px dashed #cbd5e1;"><h3 style="margin:0;">🧾 RECEIPT</h3><hr style="margin:15px 0;"><p><strong>Student:</strong> ${name}</p><p><strong>Amount:</strong> ₹200.00</p><p><strong>Date:</strong> ${date}</p><p><strong>UTR:</strong> ${utr}</p><p><strong>Status:</strong> <span style="background:#dcfce7;color:#16a34a;padding:2px 5px;border-radius:3px;">Course Verified</span></p><hr style="margin:15px 0;"><p style="font-size:12px;">Thank you for your payment.</p></div></div>`;

