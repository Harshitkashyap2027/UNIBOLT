        </div>
    </div>

    <div class="preview-modal" id="previewModal">
        <div class="preview-content">
            <div class="close-preview" onclick="togglePreview()">&times;</div>
            <div id="previewContainer"></div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
        // --- 1. THEMES CONFIG (30 CUSTOM) ---
        const THEMES = [
            { id: 'review_pass', icon: '✅', name: 'Review Pass' },
            { id: 'review_fail', icon: '❌', name: 'Review Fail' },
            { id: 'stats', icon: '📊', name: 'Stats' },
            { id: 'warriors', icon: '🏆', name: 'Warriors' },
            { id: 'offer', icon: '📜', name: 'Offer' },
            { id: 'welcome', icon: '🚀', name: 'Welcome' },
            { id: 'level', icon: '⚡', name: 'Level Up' },
            { id: 'badge', icon: '🏅', name: 'Badge' },
            { id: 'streak', icon: '🔥', name: 'Streak' },
            { id: 'rank', icon: '👑', name: 'Top Rank' },
            { id: 'interview', icon: '📅', name: 'Interview' },
            { id: 'reject', icon: '📉', name: 'Rejection' },
            { id: 'meeting', icon: '📹', name: 'Meeting' },
            { id: 'urgent', icon: '🚨', name: 'Urgent' },
            { id: 'security', icon: '🛡️', name: 'Security' },
            { id: 'otp', icon: '🔐', name: 'OTP' },
            { id: 'receipt', icon: '🧾', name: 'Receipt' },
            { id: 'pay_fail', icon: '💳', name: 'Pay Fail' },
            { id: 'hackathon', icon: '💻', name: 'Hackathon' },
            { id: 'webinar', icon: '🎥', name: 'Webinar' },
            { id: 'referral', icon: '🎁', name: 'Referral' },
            { id: 'reset', icon: '🔄', name: 'Reset' },
            { id: 'feedback', icon: '⭐', name: 'Feedback' },
            { id: 'maintain', icon: '🛠️', name: 'Maintain' },
            { id: 'policy', icon: '📜', name: 'Policy' },
            { id: 'id_card', icon: '🪪', name: 'ID Card' },
            { id: 'test', icon: '📝', name: 'Today Test' },
            { id: 'prepare', icon: '⚠️', name: 'Be Prepared' },
            { id: 'gold', icon: '🏆', name: 'Gold VIP' },
            { id: 'glass', icon: '🧊', name: 'Glass' }
        ];

        // --- 2. RENDER THEMES ---
        const themeGrid = document.getElementById('themeGrid');
        THEMES.forEach((t, i) => {
            const div = document.createElement('div');
            div.className = `theme-option ${i===0?'active':''}`;
            div.innerHTML = `<div class="theme-icon">${t.icon}</div><div>${t.name}</div>`;
            div.onclick = () => {
                document.querySelectorAll('.theme-option').forEach(e => e.classList.remove('active'));
                div.classList.add('active');
                document.getElementById('selectedTheme').value = t.id;
                
                // Auto-Fill
                if(CONTENT[t.id]) {
                    document.getElementById('emailSubject').value = CONTENT[t.id].sub;
                    document.getElementById('emailBody').value = CONTENT[t.id].body;
                }
            };
            themeGrid.appendChild(div);
        });

        // --- 3. AUTO CONTENT MAP ---
        const CONTENT = {
            review_pass: {sub: "Project Update: APPROVED", body: "Great job! Your submission has been approved by the mentor. The code structure is clean and meets all requirements."},
            review_fail: {sub: "Project Update: REVISION NEEDED", body: "Your submission requires changes. Feedback: 'Fix mobile responsiveness on the navbar.'"},
            stats: {sub: "Your Weekly Stats Report", body: "You gained +450 XP this week! You are currently Rank #{{Rank}} on the leaderboard."},
            warriors: {sub: "Challenge Unlocked: Code Warriors", body: "The arena is open. Prove your MERN stack mastery in this 48-hour sprint."},
            offer: {sub: "OFFICIAL INTERNSHIP OFFER", body: "We are pleased to offer you the position of Full Stack Intern. Welcome to the elite team."},
            welcome: {sub: "Welcome to UniBolt", body: "Hi {{Name}}, your account is verified. Get ready to elevate your career with real-world projects."},
            level: {sub: "Level Up! You reached Level 5", body: "Congratulations! You have unlocked new perks and a premium badge."},
            badge: {sub: "New Badge Earned!", body: "You've earned the 'Bug Squasher' badge for completing 10 bug fixes."},
            streak: {sub: "🔥 {{Streak}} Day Streak!", body: "You are on fire! Don't break the chain. Consistency is key."},
            rank: {sub: "You are Rank #{{Rank}}", body: "You are close to the Top 10. Keep trying and move up to get position in Top 10!"},
            interview: {sub: "Invitation: Technical Interview", body: "Your profile has been shortlisted. We invite you for a technical round tomorrow."},
            reject: {sub: "Application Update", body: "Thank you for applying. Unfortunately, we will not be moving forward at this time."},
            meeting: {sub: "Meeting Scheduled", body: "Your 1:1 mentorship session has been scheduled. Check the link below."},
            urgent: {sub: "ACTION REQUIRED", body: "Your profile is incomplete. Please update it within 24 hours to avoid suspension."},
            security: {sub: "Security Alert: New Login", body: "We detected a new login to your account. If this wasn't you, reset your password."},
            otp: {sub: "Your Login Code", body: "Your verification code is 8492. Do not share this with anyone."},
            invoice: {sub: "Payment Receipt", body: "We received your payment of ₹199. Transaction ID: #UB-9921."},
            failed: {sub: "Payment Failed", body: "Your transaction could not be processed. Please try a different card."},
            hackathon: {sub: "Hackathon Invitation", body: "Join us for the Code Warriors Hackathon this weekend. Prizes worth ₹50k."},
            webinar: {sub: "Live Webinar: React 19", body: "Join our expert lead for a deep dive into the new features of React 19."},
            referral: {sub: "Referral Bonus", body: "Your friend just joined! You've earned ₹50 in wallet credits."},
            reset: {sub: "Password Reset Request", body: "Click the button below to reset your password. This link expires in 30 minutes."},
            feedback: {sub: "We value your feedback", body: "How was your recent mentorship session? Rate us below."},
            maintenance: {sub: "Scheduled Maintenance", body: "UniBolt will be down for maintenance tonight from 2 AM to 4 AM."},
            policy: {sub: "Privacy Policy Update", body: "We have updated our terms of service. Please review the changes."},
            success: {sub: "Operation Successful", body: "Your request has been processed successfully."},
            neon: {sub: "Welcome to the Future", body: "Experience the new dark mode interface tailored for night owls."},
            gold: {sub: "VIP Access Granted", body: "You are now a Gold Member. Enjoy priority support and exclusive content."},
            glass: {sub: "New Design Language", body: "Check out our new glassmorphism UI update."},
            id_card: {sub: "Your Digital ID Card", body: "Your official UniBolt Student ID is ready. Please download it below."},
            test: {sub: "Assessment Alert", body: "Your scheduled test 'Full Stack Basics' is live. Good luck!"},
            prepare: {sub: "Be Prepared", body: "Upcoming evaluation in 24 hours. Please revise your modules."},
            receipt: {sub: "Payment Receipt: ₹200", body: "Payment Successful. Course Verified."} // Explicit override for receipt
        };

        // --- 4. THEME GENERATOR ---
        function getDesignHTML(style, content, name, btnType, studentData = {}) {
            // GENERATE UTR & DATA
            const utr = 'UTR' + Math.floor(Math.random() * 10000000000);
            const date = new Date().toLocaleDateString();
            
            // REPLACE VARIABLES
            let text = content.replace(/\n/g, '<br>')
                .replace('{{Name}}', name)
                .replace('{{XP}}', studentData.xp || '450')
                .replace('{{Rank}}', studentData.rank || '15')
                .replace('{{Streak}}', studentData.streak || '5')
                .replace('{{Badge}}', studentData.badge || 'Bug Squasher')
                .replace('{{Date}}', date);

            // BUTTON LOGIC
            let btn = "";
            const BTNS = { 
                dashboard: {t:"Open Dashboard", l:"https://unibolt.in/dashboard"},
                login: {t:"Login", l:"https://unibolt.in/login"},
                signup: {t:"Sign Up", l:"https://unibolt.in/register"},
                test: {t:"Start Test", l:"https://unibolt.in/test"},
                github: {t:"Connect GitHub", l:"https://unibolt.in/settings"}
            };

            // Automatic Buttons for specific themes
            if(style === 'offer') btn = `<div style="text-align:center;margin:30px 0;"><a href="https://unibolt.in/download/offer" style="background:#0284c7;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:bold;">⬇ Download Offer Letter</a></div>`;
            else if(style === 'id_card') btn = `<div style="text-align:center;margin:30px 0;"><a href="https://unibolt.in/download/id" style="background:#0284c7;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:bold;">🪪 Download ID Card</a></div>`;
            else if(style === 'test') btn = `<div style="text-align:center;margin:30px 0;"><a href="https://unibolt.in/test" style="background:#22c55e;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:bold;">📝 Start Test</a></div>`;
            else if(btnType !== 'none' && BTNS[btnType]) {
                const b = BTNS[btnType];
                const btnColor = (style === 'review_fail' || style === 'urgent' || style === 'failed') ? '#ef4444' : '#0284c7';
