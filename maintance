<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UniBolt - Ultra Command Center</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* --- 1. ULTRA DARK PRO UI --- */
        :root { 
            --primary: #38bdf8; 
            --secondary: #6366f1;
            --bg: #020617; 
            --surface: #0f172a; 
            --border: #1e293b; 
            --text: #f8fafc; 
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
        }
        
        * { box-sizing: border-box; }
        body { background: var(--bg); font-family: 'Segoe UI', 'Inter', sans-serif; color: var(--text); margin: 0; display: flex; height: 100vh; overflow: hidden; }
        
        /* Sidebar */
        .sidebar { width: 260px; background: #000; border-right: 1px solid var(--border); padding: 25px; display: flex; flex-direction: column; z-index: 10; }
        .brand { font-size: 22px; font-weight: 800; margin-bottom: 40px; display: flex; align-items: center; gap: 12px; color: white; letter-spacing: -0.5px; }
        .nav-item { padding: 14px; color: #64748b; cursor: pointer; border-radius: 10px; margin-bottom: 5px; display: flex; align-items: center; gap: 12px; transition: 0.2s; text-decoration: none; font-weight: 500; }
        .nav-item:hover, .nav-item.active { background: var(--surface); color: var(--primary); border-left: 3px solid var(--primary); }
        .nav-item i { width: 20px; text-align: center; }

        .main { flex: 1; display: flex; flex-direction: column; height: 100vh; }
        
        /* Top Bar */
        .top-bar { padding: 15px 30px; border-bottom: 1px solid var(--border); background: #0b1121; display: flex; justify-content: space-between; align-items: center; height: 70px; }
        .status-badge { background: rgba(34, 197, 94, 0.1); color: var(--success); padding: 5px 10px; border-radius: 20px; font-size: 11px; font-weight: bold; border: 1px solid rgba(34, 197, 94, 0.2); }
        .preview-btn { background: #1e293b; border: 1px solid #334155; color: white; padding: 10px 20px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; transition: 0.2s; }
        .preview-btn:hover { border-color: var(--primary); color: var(--primary); background: rgba(56, 189, 248, 0.1); }

        .content-area { flex: 1; display: flex; overflow: hidden; }

        /* Left Panel: List */
        .list-panel { width: 380px; border-right: 1px solid var(--border); display: flex; flex-direction: column; background: #0b1121; }
        .list-header { padding: 20px; border-bottom: 1px solid var(--border); }
        
        .bulk-controls { display: flex; gap: 10px; margin-top: 15px; }
        .mini-btn { background: var(--surface); border: 1px solid var(--border); color: #94a3b8; padding: 8px; border-radius: 6px; font-size: 11px; cursor: pointer; flex: 1; transition: 0.2s; font-weight: bold; text-transform: uppercase; }
        .mini-btn:hover { border-color: var(--primary); color: white; }
        .mini-btn.active { background: var(--primary); color: black; border-color: var(--primary); }

        .search-box { margin-top: 15px; position: relative; }
        .search-input { width: 100%; background: var(--surface); border: 1px solid var(--border); color: white; padding: 12px 12px 12px 40px; border-radius: 8px; outline: none; box-sizing: border-box; font-size: 14px; transition: 0.2s; }
        .search-input:focus { border-color: var(--primary); box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.1); }
        .search-icon { position: absolute; top: 12px; left: 14px; color: #64748b; font-size: 14px; }

        .student-scroll { flex: 1; overflow-y: auto; }
        .student-item { padding: 15px 20px; border-bottom: 1px solid var(--border); cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 15px; position: relative; }
        .student-item:hover { background: var(--surface); }
        .student-item.selected { background: rgba(56, 189, 248, 0.1); border-left: 3px solid var(--primary); }
        
        .bulk-check { display: none; width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer; }
        .list-panel.bulk-mode .bulk-check { display: block; }
        .list-panel.bulk-mode .avatar { display: none; }
        .avatar { width: 40px; height: 40px; background: #1e293b; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; border: 1px solid var(--border); color: #94a3b8; }

        /* Right Panel: Compose */
        .compose-panel { flex: 1; padding: 40px 50px; overflow-y: auto; max-width: 1100px; margin: 0 auto; scroll-behavior: smooth; }
        
        .header-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 25px; }
        .form-group { margin-bottom: 25px; }
        label { display: block; color: #94a3b8; font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.5px; }
        input, select, textarea { width: 100%; background: var(--surface); border: 1px solid var(--border); color: white; padding: 15px; border-radius: 10px; box-sizing: border-box; outline: none; font-family: inherit; font-size: 14px; transition: 0.2s; }
        input:focus, select:focus, textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.2); }

        .recipient-badge { background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.2); color: var(--primary); padding: 14px; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; font-weight: 600; font-size: 14px; }

        /* Theme Grid */
        .theme-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-top: 5px; }
        .theme-option { background: var(--surface); border: 1px solid var(--border); padding: 15px; border-radius: 10px; cursor: pointer; text-align: center; font-size: 11px; transition: 0.2s; display: flex; flex-direction: column; align-items: center; gap: 8px; justify-content: center; min-height: 80px; }
        .theme-option:hover { border-color: var(--primary); transform: translateY(-3px); }
        .theme-option.active { background: var(--primary); color: black; border-color: var(--primary); font-weight: bold; box-shadow: 0 0 20px rgba(56, 189, 248, 0.4); }
        .theme-icon { font-size: 22px; }

        /* Progress Bar */
        .progress-container { display: none; margin-top: 25px; background: #1e293b; height: 8px; border-radius: 4px; overflow: hidden; }
        .progress-bar { width: 0%; height: 100%; background: var(--success); transition: width 0.3s; }
        .progress-text { display: none; font-size: 12px; color: var(--success); margin-top: 8px; text-align: center; font-weight: bold; }

        /* Send Button */
        .btn-3d {
            background: linear-gradient(145deg, #0ea5e9 0%, #0284c7 100%);
            color: white; border: none; padding: 18px; border-radius: 12px;
            font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
            box-shadow: 0 4px 0 #075985, 0 10px 20px rgba(0,0,0,0.2); 
            transition: 0.1s; width: 100%; font-size: 16px; margin-top: 30px; letter-spacing: 0.5px;
        }
        .btn-3d:active { transform: translateY(4px); box-shadow: 0 0 0 #075985; }
        .btn-3d:disabled { background: #334155; box-shadow: none; cursor: not-allowed; opacity: 0.6; filter: grayscale(1); }

        /* Preview Modal */
        .preview-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 2000; display: none; justify-content: center; align-items: center; backdrop-filter: blur(8px); }
        .preview-content { background: white; width: 650px; max-height: 90vh; overflow-y: auto; border-radius: 12px; position: relative; box-shadow: 0 30px 80px rgba(0,0,0,0.8); }
        .close-preview { position: absolute; top: 15px; right: 20px; color: #333; font-size: 24px; cursor: pointer; z-index: 10; background: rgba(255,255,255,0.8); border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; border: 1px solid #ddd; transition: 0.2s; }
        .close-preview:hover { background: #000; color: white; }

        .toast { position: fixed; bottom: 30px; right: 30px; background: #1e293b; color: white; padding: 16px 24px; border-radius: 12px; border-left: 5px solid var(--primary); transform: translateX(150%); transition: 0.4s; z-index: 3000; font-weight: bold; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
        .toast.show { transform: translateX(0); }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="brand"><i class="fa-solid fa-bolt" style="color:var(--primary);"></i> UniBolt Admin</div>
        <a href="admin.html" class="nav-item"><i class="fa-solid fa-users"></i> Students</a>
        <a href="mail-dashboard.html" class="nav-item active"><i class="fa-solid fa-envelope"></i> Mail Center</a>
        <div style="margin-top:auto;"><a href="index.html" class="nav-item"><i class="fa-solid fa-power-off"></i> Logout</a></div>
    </div>

    <div class="main">
